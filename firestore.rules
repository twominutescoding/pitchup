rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: je li korisnik autentificiran?
    function isAuth() {
      return request.auth != null;
    }

    // Helper: je li korisnikov email na whitelisti?
    // users kolekcija koristi email kao document ID.
    // Dvoslojna zaštita: Firebase Auth + email whitelist u Firestore.
    function emailAllowed() {
      return isAuth() &&
        exists(/databases/$(database)/documents/users/$(request.auth.token.email));
    }

    // Helper: je li korisnik admin?
    function isAdmin() {
      return emailAllowed() &&
        get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.role == 'admin';
    }

    // ── users kolekcija (doc ID = email) ─────────────────────────────
    // Čitanje: autentificirani (trebaju provjeriti sebe za whitelist).
    // Pisanje: admini mogu sve; korisnik može update-ati samo svoj doc (nick polje).
    match /users/{email} {
      allow read:  if isAuth();
      allow write: if isAdmin();
      allow update: if isAuth() &&
        request.auth.token.email == email &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['nick']);
    }

    // ── config/session ───────────────────────────────────────────────
    // Čitanje: whitelisted. Pisanje: samo admini.
    match /config/{docId} {
      allow read:  if emailAllowed();
      allow write: if isAdmin();
    }

    // ── players ──────────────────────────────────────────────────────
    // Čitanje: whitelisted. Pisanje: whitelisted (igrač se može prijaviti).
    match /players/{playerId} {
      allow read:  if emailAllowed();
      allow write: if emailAllowed();
    }

    // ── history ──────────────────────────────────────────────────────
    // Čitanje: whitelisted. Pisanje: samo admini.
    match /history/{matchId} {
      allow read:  if emailAllowed();
      allow write: if isAdmin();
    }

    // ── ratings ──────────────────────────────────────────────────────
    // Čitanje: whitelisted. Pisanje: whitelisted (samo za sebe kao rater).
    match /ratings/{ratingId} {
      allow read:  if emailAllowed();
      allow create: if emailAllowed() &&
        request.resource.data.rater == get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.nick;
      allow update, delete: if false;
    }
  }
}
